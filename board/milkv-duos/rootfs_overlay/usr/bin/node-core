#!/usr/bin/env python3
import subprocess, sys, json
from bs4 import BeautifulSoup

def sovereign_extract(url):
    """Launch Ladybird headless to strip the 'Product' elements."""
    try:
        # 2026 Headless standard for Ladybird
        cmd = ['ladybird', '--headless', '--no-images', '--dump-dom', url]
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        soup = BeautifulSoup(res.stdout, 'html.parser')
        
        # Strip ads, tracking scripts, and nav bloat
        for noise in ['script', 'style', 'nav', 'footer', 'iframe', 'ad']:
            [s.decompose() for s in soup.find_all(noise)]
            
        return soup.get_text(separator='\n', strip=True)
    except Exception as e:
        return f"Crawl Error: {e}"

def search_logic(query):
    """DDGR search results piped through the extractor."""
    print(f"[*] Pioneer Search: {query}")
    raw_results = subprocess.check_output(['ddgr', '--json', query])
    data = json.loads(raw_results)
    if data:
        # Extract content from the top sovereign result
        print(sovereign_extract(data[0]['url']))

if __name__ == "__main__":
    if len(sys.argv) > 1:
        search_logic(" ".join(sys.argv[1:]))
